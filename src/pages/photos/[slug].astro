---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DownloadButton from '../../components/DownloadButton.astro';
import TipPrompt from '../../components/TipPrompt.astro';
import { loadShoot, slugify, webSrc, webSrcSet, type Photo } from '../../lib/config';
import photosData from '../../data/photos.json';

export async function getStaticPaths() {
  const { loadShoot } = await import('../../lib/config');
  const shoot = loadShoot();
  const all = (await import('../../data/photos.json')).default as Photo[];
  const photos = all.filter((p) => p.filename !== shoot.shoot.hero);
  return photos.map((photo, index) => ({
    params: { slug: slugify(photo.filename) },
    props: {
      photo,
      prev: photos[index - 1] ?? null,
      next: photos[index + 1] ?? null,
      index,
      total: photos.length,
    },
  }));
}

interface Props {
  photo: Photo;
  prev: Photo | null;
  next: Photo | null;
  index: number;
  total: number;
}

const { photo, prev, next, index, total } = Astro.props;
const shoot = loadShoot();
const downloadSrc = `/photos/${photo.filename}`;
const viewSrc = webSrc(photo.filename, 1600);
const viewSrcSet = webSrcSet(photo.filename, [1024, 1600, 2048]);
const prevSlug = prev ? slugify(prev.filename) : null;
const nextSlug = next ? slugify(next.filename) : null;
---

<BaseLayout
  title={photo.caption}
  description={photo.alt}
  image={downloadSrc}
  imageAlt={photo.alt}
  tags={photo.tags}
  type="article"
>
  <div class="mx-auto max-w-6xl px-6 md:px-10 pt-10 md:pt-14">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 transition-colors"
    >
      <span aria-hidden="true">←</span>
      Back to {shoot.shoot.title}
    </a>
  </div>

  <figure class="mx-auto max-w-6xl px-6 md:px-10 mt-8 md:mt-10">
    <div class="relative bg-stone-200 dark:bg-stone-900 overflow-hidden">
      <img
        src={viewSrc}
        srcset={viewSrcSet}
        sizes="(min-width: 1280px) 1200px, 100vw"
        alt={photo.alt}
        class="w-full h-auto block"
        fetchpriority="high"
        decoding="async"
      />
      <TipPrompt id="tip-prompt" />
    </div>
  </figure>

  <section class="mx-auto max-w-3xl px-6 md:px-10 mt-10 md:mt-12">
    <p class="text-xs tabular tracking-wide uppercase text-stone-500 dark:text-stone-400">
      {String(index + 1).padStart(2, '0')} / {String(total).padStart(2, '0')}
    </p>
    <h1 class="mt-3 font-display text-3xl md:text-5xl tracking-tight leading-[1.05]">
      {photo.caption}
    </h1>
    <p class="mt-5 text-base md:text-lg text-stone-600 dark:text-stone-400 leading-relaxed max-w-prose">
      {photo.alt}
    </p>

    {photo.tags.length > 0 && (
      <ul class="mt-6 flex flex-wrap gap-2">
        {photo.tags.map((t) => (
          <li>
            <a
              href={`/tags/${t.toLowerCase()}/`}
              class="inline-block text-xs text-stone-500 dark:text-stone-400 px-2 py-1 border border-stone-200 dark:border-stone-800 hover:border-stone-900 dark:hover:border-stone-100 hover:bg-stone-900 dark:hover:bg-stone-100 hover:text-stone-50 dark:hover:text-stone-900 transition-colors"
            >
              {t}
            </a>
          </li>
        ))}
      </ul>
    )}

    <div class="mt-10">
      <DownloadButton href={downloadSrc} filename={photo.filename} revealId="tip-prompt" />
    </div>
  </section>

  <nav class="mx-auto max-w-6xl px-6 md:px-10 mt-20 md:mt-28 pb-4 flex items-center justify-between text-sm">
    {prevSlug ? (
      <a href={`/photos/${prevSlug}/`} class="group flex flex-col gap-1">
        <span class="text-xs tabular uppercase tracking-wide text-stone-500 dark:text-stone-400">Previous</span>
        <span class="font-display text-lg md:text-xl group-hover:underline">{prev!.caption}</span>
      </a>
    ) : <span></span>}
    {nextSlug ? (
      <a href={`/photos/${nextSlug}/`} class="group flex flex-col gap-1 text-right">
        <span class="text-xs tabular uppercase tracking-wide text-stone-500 dark:text-stone-400">Next</span>
        <span class="font-display text-lg md:text-xl group-hover:underline">{next!.caption}</span>
      </a>
    ) : <span></span>}
  </nav>
</BaseLayout>
