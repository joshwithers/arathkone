---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { loadShoot, ogSrc, OG_DIMENSIONS } from '../lib/config';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  tags?: string[];
  publishedTime?: string;
}

const shoot = loadShoot();
const {
  title,
  description = shoot.shoot.blurb,
  image,
  imageAlt,
  type = 'website',
  tags = [],
  publishedTime = shoot.shoot.date,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const rawImage = image ?? `/photos/${shoot.shoot.hero}`;
const photoMatch = rawImage.match(/\/photos\/([^/]+)$/);
const ogPath = photoMatch ? ogSrc(photoMatch[1]) : rawImage;
const ogImage = ogPath.startsWith('http') ? ogPath : new URL(ogPath, Astro.site).toString();
const ogImageAlt = imageAlt ?? description;
const siteName = shoot.shoot.title;
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;

const jsonLD = type === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'ImageObject',
      name: title,
      caption: title,
      description,
      contentUrl: ogImage,
      datePublished: publishedTime,
      creator: { '@type': 'Person', name: shoot.photographer.name },
      contentLocation: { '@type': 'Place', name: shoot.shoot.location },
      isPartOf: {
        '@type': 'PhotoGallery',
        name: shoot.shoot.title,
        url: Astro.site?.toString(),
      },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'PhotoGallery',
      name: shoot.shoot.title,
      description: shoot.shoot.blurb,
      url: Astro.site?.toString(),
      datePublished: shoot.shoot.date,
      contentLocation: { '@type': 'Place', name: shoot.shoot.location },
      creator: { '@type': 'Person', name: shoot.photographer.name },
      image: ogImage,
    };

const socials = [
  shoot.photographer.instagram && { name: 'Instagram', href: shoot.photographer.instagram, icon: 'instagram' },
  shoot.photographer.threads && { name: 'Threads', href: shoot.photographer.threads, icon: 'threads' },
  shoot.photographer.vero && { name: 'Vero', href: shoot.photographer.vero, icon: 'vero' },
  shoot.photographer.fotoapp && { name: 'Foto App', href: shoot.photographer.fotoapp, icon: 'fotoapp' },
  shoot.photographer.kofi && { name: 'Ko-fi', href: shoot.photographer.kofi, icon: 'kofi', accent: true },
].filter(Boolean) as Array<{ name: string; href: string; icon: string; accent?: boolean }>;
---

<!DOCTYPE html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={shoot.photographer.name} />
    <link rel="canonical" href={canonicalURL} />

    <ClientRouter />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content={String(OG_DIMENSIONS.width)} />
    <meta property="og:image:height" content={String(OG_DIMENSIONS.height)} />
    <meta property="og:image:alt" content={ogImageAlt} />

    {type === 'article' && (
      <>
        <meta property="article:published_time" content={publishedTime} />
        <meta property="article:author" content={shoot.photographer.name} />
        <meta property="article:section" content={shoot.shoot.title} />
        {tags.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />
  </head>
  <body class="bg-stone-50 text-stone-900 dark:bg-stone-950 dark:text-stone-100 antialiased">
    <main><slot /></main>

    <footer class="mx-auto max-w-6xl px-6 md:px-10 pt-24 pb-16 mt-24 border-t border-stone-200 dark:border-stone-800">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-12 md:gap-20 items-start">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-stone-500 dark:text-stone-400 mb-5">
            About Dan
          </p>
          <div class="flex items-start gap-5">
            {shoot.photographer.portrait && (
              <figure class="shrink-0">
                <img
                  src={shoot.photographer.portrait}
                  alt={`Portrait of ${shoot.photographer.name}`}
                  width="96"
                  height="96"
                  loading="lazy"
                  decoding="async"
                  class="w-20 h-20 md:w-24 md:h-24 object-cover shadow-sm"
                />
                {shoot.photographer.portrait_credit && (
                  <figcaption class="mt-2 text-[10px] text-stone-600 dark:text-stone-400 tabular tracking-wide leading-tight">
                    Photo: {shoot.photographer.portrait_credit}
                  </figcaption>
                )}
              </figure>
            )}
            <div>
              <p class="font-display text-2xl md:text-3xl tracking-tight leading-tight">{shoot.photographer.name}</p>
              {shoot.photographer.location && (
                <p class="mt-1 text-xs text-stone-500 dark:text-stone-400 tabular tracking-wide uppercase">
                  {shoot.photographer.location}
                </p>
              )}
            </div>
          </div>
          {shoot.photographer.bio && (
            <p class="mt-6 max-w-md text-sm md:text-base text-stone-600 dark:text-stone-400 leading-relaxed">
              {shoot.photographer.bio}
            </p>
          )}
        </div>

        {socials.length > 0 && (
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-stone-500 dark:text-stone-400 mb-4">
              Follow Dan
            </p>
            <ul class="flex flex-wrap gap-2 md:gap-3">
              {socials.map((s) => (
                <li>
                  <a
                    href={s.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={s.name}
                    class:list={[
                      'group relative inline-flex items-center gap-2.5 h-12 px-4 border transition-all duration-300 overflow-hidden',
                      s.accent
                        ? 'border-amber-500 text-amber-700 dark:text-amber-400 hover:bg-amber-500 hover:text-stone-950 dark:hover:text-stone-950'
                        : 'border-stone-300 dark:border-stone-700 hover:border-stone-900 dark:hover:border-stone-100 hover:bg-stone-900 dark:hover:bg-stone-100 hover:text-stone-50 dark:hover:text-stone-900',
                    ]}
                  >
                    <span class="w-5 h-5 flex items-center justify-center shrink-0">
                      {s.icon === 'instagram' && (
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect x="3" y="3" width="18" height="18" rx="5"/>
                          <circle cx="12" cy="12" r="4"/>
                          <circle cx="17.3" cy="6.7" r="1.1" fill="currentColor" stroke="none"/>
                        </svg>
                      )}
                      {s.icon === 'threads' && (
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M17.5 10.5c-.5-2.5-2.5-4-5-4-3 0-5 1.8-5.5 4.5-.6 3 .5 6 3 7.5 2 1.2 5 1.2 6.8-.5 1.6-1.5 1.7-3.7-.3-4.8-1.5-.8-3.7-.7-4.8.5-.9 1-.7 2.4.5 2.9"/>
                          <circle cx="12" cy="12" r="9"/>
                        </svg>
                      )}
                      {s.icon === 'vero' && (
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <circle cx="12" cy="12" r="9"/>
                          <path d="M7.5 8.5L12 16l4.5-7.5"/>
                        </svg>
                      )}
                      {s.icon === 'fotoapp' && (
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <circle cx="12" cy="12" r="9"/>
                          <path d="M12 3v9M19.8 7.5L12 12M19.8 16.5L12 12M12 21v-9M4.2 16.5L12 12M4.2 7.5L12 12"/>
                        </svg>
                      )}
                      {s.icon === 'kofi' && (
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M10 3v3M14 3v3"/>
                          <path d="M5 9h13v7a4 4 0 0 1-4 4H9a4 4 0 0 1-4-4V9z"/>
                          <path d="M18 11h1.5a2.5 2.5 0 0 1 0 5H18"/>
                        </svg>
                      )}
                    </span>
                    <span class="text-sm font-medium tracking-tight">{s.name}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <p class="mt-14 text-xs text-stone-600 dark:text-stone-400 tabular">
        Photographs © {new Date(shoot.shoot.date).getFullYear()} {shoot.photographer.name}
      </p>
    </footer>
  </body>
</html>
