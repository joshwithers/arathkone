---
interface Props {
  href: string;
  filename: string;
  revealId?: string;
}

const { href, filename, revealId = 'tip-prompt' } = Astro.props;
---

<a
  href={href}
  download={filename}
  data-reveal={revealId}
  class="inline-flex items-center gap-3 px-6 py-3 bg-stone-900 text-stone-50 dark:bg-stone-100 dark:text-stone-900 text-sm font-medium hover:bg-stone-700 dark:hover:bg-stone-300 transition-colors"
>
  Download
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
    <path d="M7 1v9m0 0l-3.5-3.5M7 10l3.5-3.5M1 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</a>
