---
import { loadShoot } from '../lib/config';

interface Props {
  id?: string;
}

const { id = 'tip-prompt' } = Astro.props;
const shoot = loadShoot();
---

<div
  id={id}
  data-tip-overlay
  class="absolute inset-0 z-10 flex items-center justify-center p-6 md:p-10 pointer-events-none opacity-0 transition-opacity duration-500 ease-out data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto"
  aria-hidden="true"
>
  <button
    type="button"
    data-tip-backdrop
    class="absolute inset-0 w-full h-full bg-stone-950/70 backdrop-blur-md cursor-default"
    aria-label="Dismiss"
  ></button>

  <div
    data-tip-card
    class="relative w-full max-w-md bg-stone-50 dark:bg-stone-900 text-stone-900 dark:text-stone-100 p-8 md:p-10 shadow-2xl scale-[0.96] transition-transform duration-500 ease-out"
    style="transition-timing-function: cubic-bezier(0.2, 0.9, 0.3, 1.1);"
  >
    <button
      type="button"
      data-tip-close
      class="absolute top-3 right-3 p-2 text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 transition-colors"
      aria-label="Close"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <p class="text-xs uppercase tracking-[0.2em] text-stone-500 dark:text-stone-400">
      Download started
    </p>
    <p class="mt-4 font-display text-3xl md:text-4xl tracking-tight leading-[1.05]">
      If it landed, shout Dan a coffee.
    </p>
    <p class="mt-4 text-sm md:text-base text-stone-600 dark:text-stone-400 leading-relaxed">
      Photos are free. Tips keep the shutter clicking.
    </p>

    <a
      href={shoot.photographer.kofi}
      target="_blank"
      rel="noopener noreferrer"
      class="group mt-8 inline-flex items-center gap-3 w-full justify-center px-6 py-4 bg-amber-500 hover:bg-amber-400 text-stone-950 font-medium text-base transition-colors"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M11 7h2M8 4v6m8-6v6M6 10h12v7a3 3 0 01-3 3H9a3 3 0 01-3-3v-7zm12 0h1a3 3 0 010 6h-1" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>Tip on Ko-fi</span>
      <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
    </a>

    <button
      type="button"
      data-tip-close
      class="mt-4 w-full text-center text-xs text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 transition-colors py-2"
    >
      No thanks
    </button>
  </div>
</div>

<script>
  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-tip-overlay]').forEach((overlay) => {
      if (overlay.dataset.bound) return;
      overlay.dataset.bound = 'true';

      const card = overlay.querySelector<HTMLElement>('[data-tip-card]');
      const tipLink = overlay.querySelector<HTMLAnchorElement>('a[href]');
      const closers = overlay.querySelectorAll<HTMLElement>('[data-tip-close], [data-tip-backdrop]');

      const open = () => {
        overlay.dataset.open = 'true';
        overlay.setAttribute('aria-hidden', 'false');
        if (card) card.style.transform = 'scale(1)';
        overlay.scrollIntoView({ behavior: 'smooth', block: 'center' });
        window.setTimeout(() => tipLink?.focus({ preventScroll: true }), 650);
      };
      const close = () => {
        overlay.dataset.open = 'false';
        overlay.setAttribute('aria-hidden', 'true');
        if (card) card.style.transform = '';
      };

      closers.forEach((el) => el.addEventListener('click', close));

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay.dataset.open === 'true') close();
      });

      (overlay as any)._openTip = open;
    });

    document.querySelectorAll<HTMLAnchorElement>('a[data-reveal]').forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', () => {
        const id = btn.dataset.reveal;
        if (!id) return;
        const target = document.getElementById(id) as any;
        if (target?._openTip) {
          setTimeout(() => target._openTip(), 450);
        }
      });
    });
  };

  init();
  document.addEventListener('astro:after-swap', init);
</script>
